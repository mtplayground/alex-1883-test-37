# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Frontend
# Leave empty when the frontend and API share an origin.
VITE_API_BASE_URL=http://localhost:8080

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/myclawteam?sslmode=require

# S3-compatible object storage
OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me
OBJECT_STORAGE_BUCKET=myclawteam
OBJECT_STORAGE_ENDPOINT=https://storage.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_PREFIX=myclawteam
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Google OAuth
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback

# JWT sessions
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
